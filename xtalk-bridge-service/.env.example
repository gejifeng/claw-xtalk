# Sidecar network
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=7431

# DashScope / Aliyun credentials
DASHSCOPE_API_KEY=

# Official ASR provider
ASR_PROVIDER=qwen-realtime
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_ASR_LANGUAGE=zh
QWEN_ASR_SAMPLE_RATE=16000
QWEN_ASR_TURN_DETECTION_THRESHOLD=0.35
QWEN_ASR_TURN_DETECTION_SILENCE_MS=550

# Optional local Whisper fallback
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=zh
VAD_ENERGY_THRESHOLD=200.0
VAD_SILENCE_MS=800
VAD_PARTIAL_INTERVAL_MS=1500

# TTS selection
TTS_ENABLED=1
TTS_PROVIDER=aliyun-cosyvoice

# Official CosyVoice TTS
# For quick smoke tests, cosyvoice-v3-flash + longanyang is the easiest combination.
# For cosyvoice-v3.5-flash, ALIYUN_COSYVOICE_VOICE must be a valid clone/design voice ID.
ALIYUN_COSYVOICE_MODEL=cosyvoice-v3-flash
ALIYUN_COSYVOICE_VOICE=longanyang
ALIYUN_COSYVOICE_AUDIO_FORMAT=PCM_24000HZ_MONO_16BIT
ALIYUN_COSYVOICE_VOLUME=50
ALIYUN_COSYVOICE_SPEECH_RATE=1.0
ALIYUN_COSYVOICE_PITCH_RATE=1.0
ALIYUN_COSYVOICE_INSTRUCTION=
ALIYUN_COSYVOICE_TIMEOUT_MS=30000

# Optional local CosyVoice fallback
COSYVOICE_REPO_DIR=./vendor/CosyVoice
TTS_MODEL_DIR=./pretrained_models/Fun-CosyVoice3-0.5B
TTS_MODE=zero_shot
TTS_SPEAKER_ID=中文女
TTS_SPEED=1.0
TTS_PROMPT_TEXT=You are a helpful assistant.<|endofprompt|>希望你以后能够做的比我还好呦。
TTS_PROMPT_WAV=./vendor/CosyVoice/asset/zero_shot_prompt.wav
TTS_INSTRUCT_TEXT=

# Local reference audio folder for custom voice material
REFERENCE_AUDIO_DIR=./reference-audio

# ─────────────────────────────────────────────────────────────────────────────
# OmniVoice TTS  (local high-performance diffusion model)
# ─────────────────────────────────────────────────────────────────────────────
# Activate with: TTS_PROVIDER=omnivoice
#
# OmniVoice is a locally-running diffusion-language TTS model.  On a warm GPU
# with the default 8 diffusion steps, the time-to-first-audio is roughly
# 970–1 250 ms (RTF ≈ 0.10–0.47).  No cloud API key is required.  Model
# weights are downloaded automatically from HuggingFace the first time the
# sidecar starts when OMNIVOICE_MODEL_DIR does not yet exist.
#
# China users: set HF_ENDPOINT=https://hf-mirror.com in the environment before
# starting the service to redirect the HuggingFace download through a mirror.

# HuggingFace model identifier — used only when OMNIVOICE_MODEL_DIR is absent.
OMNIVOICE_MODEL=k2-fsa/OmniVoice

# Local directory where the model weights are stored / will be downloaded.
# If the directory exists the sidecar loads from disk without hitting the network.
OMNIVOICE_MODEL_DIR=./pretrained_models/OmniVoice

# Compute device.  Use cuda:0 (default) for a single NVIDIA GPU, cpu for
# CPU-only machines, or mps for Apple Silicon (slower, experimental).
OMNIVOICE_DEVICE=cuda:0

# Weight dtype.  float16 is recommended on CUDA (halves VRAM, no quality loss).
# Use float32 on CPU or MPS where float16 is unsupported.
OMNIVOICE_DTYPE=float16

# Number of diffusion denoising steps.
# 8  → ~970–1 250 ms TTFA — recommended for real-time conversation.
# 16 → marginally better prosody, roughly 2× slower.
# Avoid >= 32 in live sessions; the quality gain is negligible.
OMNIVOICE_NUM_STEP=8

# Classifier-free guidance scale.  2.0 is the recommended default.
# Higher values increase style adherence but can introduce artefacts.
OMNIVOICE_GUIDANCE_SCALE=2.0

# Speaking speed multiplier.  1.0 = natural speed, 1.2 = 20% faster.
OMNIVOICE_SPEED=1.0

# ── Voice mode (choose exactly one of the three options below) ────────────────
#
# Option 1 — Voice cloning (highest quality, requires a reference recording):
#   Set OMNIVOICE_REF_AUDIO to a mono WAV/MP3 file of 3–10 seconds.
#   Set OMNIVOICE_REF_TEXT  to the transcript of the reference (optional but
#   recommended — skips the built-in Whisper ASR, saving ~500 MB VRAM and
#   several seconds of startup time).
OMNIVOICE_REF_AUDIO=
OMNIVOICE_REF_TEXT=
#
# Option 2 — Voice design (no reference recording needed):
#   Set OMNIVOICE_INSTRUCT to a comma-separated attribute description.
#   Examples: "female, low pitch"  /  "male, energetic, fast"
#   INSTRUCT is ignored when REF_AUDIO is set.
OMNIVOICE_INSTRUCT=
#
# Option 3 — Auto voice:
#   Leave REF_AUDIO, REF_TEXT, and INSTRUCT all empty.
#   OmniVoice selects a built-in voice automatically.